// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  password           String
  email              String?  @unique
  fullName           String?
  address            String?
  birthday           DateTime?
  age                Int?
  gender             String?
  location           String?
  relationshipStatus String?
  seniorIdNumber     String?  @unique
  nationalIdNumber   String?  @unique
  pensioner          Boolean?
  birthplace         String?
  philsysId          String?
  hasNoId            Boolean  @default(false)
  role               String   @default("USER")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  idDocuments        IdDocument[]

  @@map("users")
}

model IdDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String
  url       String
  createdAt DateTime @default(now())

  @@map("id_documents")
}
